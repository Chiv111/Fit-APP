# ============================================================
# CONFIGURACIÓN DE SUPABASE (REQUERIDA para multi-cuenta)
# ============================================================
# 1. Crea un proyecto gratis en https://supabase.com
# 2. Settings -> API -> copia "Project URL" y "anon public key"
# 3. Pega los valores aquí y guarda como .env (sin la palabra "example")
# 4. En el SQL Editor de Supabase, ejecuta el archivo:
#    supabase/migrations/20260304_lockin_state_user.sql
# 5. En Authentication -> Providers, habilita "Email"
# 6. (Opcional) Authentication -> Settings, desactiva
#    "Confirm email" si quieres que el signup entre directo sin
#    verificación de correo.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL a la que vuelve el link de recuperación de contraseña.
# Si no configuras, usa window.location.origin (la URL actual).
VITE_SUPABASE_AUTH_REDIRECT_URL=

# Si dejas las claves vacías, la app funcionará en modo solo-local:
# todos los datos se guardan únicamente en este dispositivo,
# sin sincronización y sin sistema de cuentas.
