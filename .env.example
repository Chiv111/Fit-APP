# Configuración pública del frontend. Nunca uses aquí service_role ni sb_secret.
# El proyecto se enlaza con:
#   supabase link --project-ref boejvavrpolvtabunddo
# Las migraciones se aplican con:
#   supabase db push

VITE_SUPABASE_URL=https://boejvavrpolvtabunddo.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# URL a la que vuelve el link de recuperación de contraseña.
# Si no configuras, usa window.location.origin (la URL actual).
VITE_SUPABASE_AUTH_REDIRECT_URL=

# La app también acepta VITE_SUPABASE_ANON_KEY por compatibilidad con proyectos
# antiguos, pero para instalaciones nuevas usa la clave publishable.
